{
  "rewrites": [
    {
      "source": "/(assets|canvaskit|icons)/(.*)",
      "destination": "/build/web/$1/$2"
    },
    {
      "source": "/(flutter|main|manifest|version|favicon|flutter_bootstrap|flutter_service_worker)(.*)",
      "destination": "/build/web/$1$2"
    },
    {
      "source": "/(.*)",
      "destination": "/build/web/index.html"
    }
  ]
}
